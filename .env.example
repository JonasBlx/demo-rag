# Copy this file to .env and fill in the values.
#   cp .env.example .env

# --- Required: Anthropic Claude (generation) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Generation model ---
# Default. Higher-quality alternative: claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# Cap on generated tokens per answer (cost guardrail).
MAX_TOKENS=1024

# Number of chunks retrieved per question.
RETRIEVAL_K=4

# Per-session question limit (cost/abuse guardrail on a public demo).
MAX_QUESTIONS_PER_SESSION=20

# --- Embeddings ---
# Anthropic has no embeddings endpoint, so embeddings come from elsewhere.
# Questions are assumed to be in English, so an English model is appropriate.
# EMBEDDING_BACKEND selects the provider: "local" (default) or "voyage".
#
#   local  -> sentence-transformers, runs on your machine, no API key, free.
#   voyage -> Voyage AI (Anthropic's recommended embedding partner), needs a key.
EMBEDDING_BACKEND=local

# Used when EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Used when EMBEDDING_BACKEND=voyage (https://www.voyageai.com/)
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3.5
